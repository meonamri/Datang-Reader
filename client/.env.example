# Datang Reader - Client Environment Configuration
# Copy this file to .env and source it before running the GUI client
# IMPORTANT: Never commit .env to version control!
#
# Usage:
#   cp .env.example .env
#   nano .env  # Edit values
#
# The GUI launcher (run-gui.sh) automatically loads this file.

# Container URL
# The URL of the Datang Reader server (Docker container or remote server)
# For local Docker: http://localhost:8080
# For Tailscale remote: https://datang-reader.<tailnet>.ts.net
DATANG_CONTAINER_URL=http://localhost:8080

# GUI Fullscreen Mode
# Set to 'true' to launch GUI in fullscreen, 'false' for windowed mode
DATANG_FULLSCREEN=false

# Pulse Animation (idle breathe effect on the RFID puck)
# Set to 'false' to disable if experiencing performance issues on low-end hardware
DATANG_ENABLE_PULSE=true

# Pulse Animation FPS
# Frames per second for the idle breathe animation (default: 30)
# Lower values reduce CPU usage on ARM hardware (e.g. 12 for OrangePi Zero 3)
DATANG_PULSE_FPS=30
