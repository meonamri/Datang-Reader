# IDME portal test credentials — COPY this to `.idme-test.env` and fill in.
# `.idme-test.env` is gitignored; never commit real credentials.
#
#   cp .idme-test.env.example .idme-test.env
#   # then edit .idme-test.env

# Teacher IC number (12 digits, no dashes)
IDME_TEST_IC=

# Teacher IDME/MOEIS password (plaintext)
IDME_TEST_PASSWORD=
