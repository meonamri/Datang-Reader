# Datang Reader - Server Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# ===================================================================
# DATANG API CONFIGURATION
# ===================================================================

# API Base URL (no trailing slash)
DATANG_API_BASE_URL=https://datang.my/api/reader/v1

# Reader Credentials
# Format: {school_id}_reader{number}
DATANG_READER_USERNAME=your_username_here
DATANG_READER_PASSWORD=your_password_here

# Device Identification
# Unique identifier for this reader terminal
DATANG_DEVICE_ID=docker-reader-01

# Mock API Mode (for testing without real API)
# Set to 'true' for development/testing, 'false' for production
DATANG_MOCK_API=false

# Host port mapping (the port exposed on the host machine)
# The container always listens on 8080 internally
DATANG_HOST_PORT=8080


# ===================================================================
# IDME MODULE (Optional - Automated IDME Portal Submission)
# ===================================================================
# Set IDME_ENABLED=true to activate automated attendance submission
# to the IDME/MOEIS portal. Teacher credentials are managed via
# the Web UI at http://localhost:8080/idme/settings

# Enable/disable IDME module
IDME_ENABLED=false

# Daily cutoff time for automatic IDME submission (24h format HH:MM)
# At this time, all students who haven't scanned are marked absent
IDME_CUTOFF_TIME=09:00

# Fernet encryption key for teacher password storage
# Generate one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Generate once, never change (or all stored passwords become invalid)
IDME_ENCRYPTION_KEY=

# Debug mode - saves screenshots during IDME automation (useful for troubleshooting)
IDME_DEBUG=false
