# Datang Reader - Server Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# API Base URL (no trailing slash)
DATANG_API_BASE_URL=https://datang.my/api/reader/v1

# Reader Credentials
# Format: {school_id}_reader{number}
DATANG_READER_USERNAME=30370_reader78
DATANG_READER_PASSWORD=your_password_here

# Device Identification
# Unique identifier for this reader terminal
DATANG_DEVICE_ID=docker-reader-01

# Mock API Mode (for testing without real API)
# Set to 'true' for development/testing, 'false' for production
DATANG_MOCK_API=false

# Host port mapping (the port exposed on the host machine)
# The container always listens on 8080 internally
DATANG_HOST_PORT=8080
